generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CONTENT_MANAGER
  SUPPORT
  USER
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  phone      String?
  nationalId String?
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  announcements Announcement[]
  auditLogs     AuditLog[]

  @@index([name, email])
}

model Announcement {
  id        String    @id @default(cuid())
  titleEn   String
  titleAr   String
  bodyEn    String
  bodyAr    String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  auditLogs AuditLog[]

  @@index([deletedAt])
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entity         String
  entityId       String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id])
  metadata       Json?
  createdAt      DateTime      @default(now())
}
